# Copy to .env.local for dev. Production: set in compose / host env.
# Node 20: `npm run dev`/`build`/… dùng `scripts/with-node20.sh` (Node trong ~/.cursor-server/...). Không có sẵn: export KAHA_NODE20=/path/to/node
# Local (trùng `npm run dev` và Docker): http://127.0.0.1:3102 — canonical/sitemap/OG đúng origin.
NEXT_PUBLIC_SITE_URL=https://kaha.vn

# Public URL prefix cho media sau R2 (ảnh trong body HTML). Không slash cuối.
# NEXT_PUBLIC_MEDIA_BASE=https://example.r2.dev/kaha

# Chỉ database kaha_vn trên vps-postgres (kiểm tra tên DB trong URL).
# DATABASE_URL=postgresql://USER:PASS@127.0.0.1:5432/kaha_vn

# Sitemap: minimal = /, /journal, /shop, /showroom, /lookbook, /moodboard, /feed.xml. full = harvest + các route app. db = content_nodes + các route app (trùng slug thì gộp).
# KAHA_SITEMAP_MODE=minimal

# Dev: thêm link "Mockup" trong header → /home-mockup (xem docs/HOME-MOCKUP.md). Tắt trước go-live nếu không cần.
# NEXT_PUBLIC_SHOW_HOME_MOCKUP_LINK=1
